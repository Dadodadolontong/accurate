# -----------------------------------------------------------------------
# Copy this file to .env and fill in your values before running.
# -----------------------------------------------------------------------

# --- Accurate API Token credentials ------------------------------------
# API Token    : generated by the end-user in Accurate Store > API Token
#                (Settings menu > Accurate Store > API Token tab > Create API Token)
ACCURATE_API_TOKEN=your_api_token_here

# Signature Secret : found in Developer Area > Application > API Token tab
#                    Keep this confidential – never share it.
ACCURATE_SIGNATURE_SECRET=your_signature_secret_here

# Base host URL of the company's Accurate database
# Visible in the JSON response when the API Token is created, e.g.:
#   "host": "https://zeus.accurate.id"
ACCURATE_HOST=https://yoursubdomain.accurate.id

# --- ClickHouse connection ---------------------------------------------
CH_HOST=localhost
CH_PORT=8123          # HTTP port (use 8443 for HTTPS / ClickHouse Cloud)
CH_DATABASE=accurate_data
CH_USER=default
CH_PASSWORD=your_clickhouse_password
CH_SECURE=false       # set to true for ClickHouse Cloud or TLS deployments

# --- Sync settings -----------------------------------------------------
# Records fetched per API page (max supported by Accurate)
PAGE_SIZE=100

# How often the scheduler runs (minutes)
SYNC_INTERVAL_MINUTES=60
