import json
import logging
from datetime import datetime
from db_manager import _get_client, _insert_sales_invoice_items

logging.basicConfig(level=logging.INFO)

def main():
    try:
        with open('detailitems.md', 'r', encoding='utf-8') as f:
            content = f.read()
        
        content = content.strip()
        if content.startswith('"detailItem":'):
            content = "{" + content + "}"
        
        try:
            data = json.loads(content)
            if isinstance(data, dict) and "detailItem" in data:
                items = data["detailItem"]
            else:
                items = data
        except json.JSONDecodeError as e:
            # Maybe it needs closing brace?
            if "{" in content and not content.endswith("}"):
                content += "}"
                data = json.loads(content)
                if isinstance(data, dict) and "detailItem" in data:
                    items = data["detailItem"]
                else:
                    items = data
            else:
                raise e

        client = _get_client()
        now = datetime.now()
        
        # Prepare the list of tuples: (invoice_id, item_dict)
        pairs = []
        for item in items:
            invoice_id = item.get("salesInvoiceId")
            if invoice_id is None:
                print(f"Warning: salesInvoiceId missing for item {item.get('id')}")
            pairs.append((invoice_id, item))
            
        _insert_sales_invoice_items(client, now, pairs)
        print(f"Successfully inserted {len(pairs)} items.")
            
    except Exception as e:
        print(f"Error: {e}")

if __name__ == "__main__":
    main()
